<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/bg_card"
    android:paddingBottom="32dp">

    <!-- Drag handle -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="24dp"
        android:background="@drawable/bg_drag_handle" />

    <!-- Step icon -->
    <ImageView
        android:id="@+id/imgStepIcon"
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:layout_gravity="center_horizontal"
        android:background="@drawable/bg_icon_glow"
        android:padding="14dp"
        android:layout_marginBottom="20dp" />

    <!-- Step indicator pills -->
    <LinearLayout
        android:id="@+id/rowStepIndicator"
        android:layout_width="wrap_content"
        android:layout_height="8dp"
        android:layout_gravity="center_horizontal"
        android:orientation="horizontal"
        android:layout_marginBottom="24dp" />

    <!-- Title -->
    <TextView
        android:id="@+id/textStepTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="@color/text_primary"
        android:textSize="22sp"
        android:fontFamily="sans-serif-medium"
        android:textAlignment="center"
        android:paddingHorizontal="32dp"
        android:layout_marginBottom="10dp" />

    <!-- Description -->
    <TextView
        android:id="@+id/textStepDesc"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="@color/text_secondary"
        android:textSize="14sp"
        android:lineSpacingMultiplier="1.5"
        android:textAlignment="center"
        android:paddingHorizontal="32dp"
        android:layout_marginBottom="28dp" />

    <!-- Primary action button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnStepAction"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_marginHorizontal="24dp"
        android:text="Grant Permission"
        android:textColor="@color/bg_deepspace"
        android:textSize="15sp"
        android:fontFamily="sans-serif-medium"
        app:backgroundTint="@color/jarvis_primary"
        app:cornerRadius="14dp" />

    <!-- Skip / later -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnStepSkip"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:layout_marginHorizontal="24dp"
        android:layout_marginTop="8dp"
        android:text="Skip for now"
        android:textColor="@color/text_secondary"
        android:textSize="14sp"
        style="@style/Widget.MaterialComponents.Button.TextButton"
        app:rippleColor="@color/ripple_primary" />

</LinearLayout>
